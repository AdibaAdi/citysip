// CitySip data model — production schema
// PostgreSQL (+ optional PostGIS later for geo search)
//
// To enable PostGIS once your DB is up:
//   CREATE EXTENSION IF NOT EXISTS postgis;
//
// lat/lng are plain floats — fast enough for city-scale queries with a
// btree index. Swap to `geography(Point, 4326)` when you outgrow that.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  state     String
  country   String   @default("US")
  lat       Float
  lng       Float
  blurb     String?
  heroImage String?
  places    Place[]
  events    Event[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Place {
  id           String   @id @default(cuid())
  slug         String   @unique
  name         String
  cityId       String
  city         City     @relation(fields: [cityId], references: [id])
  neighborhood String?
  address      String
  zip          String?
  lat          Float
  lng          Float
  phone        String?
  website      String?
  imageUrl     String?
  priceLevel   Int      @default(2) // 1-4 ($, $$, $$$, $$$$)
  rating       Float    @default(4.2)
  reviewCount  Int      @default(0)
  vibeTags     String[] @default([]) // ["rooftop","date-night","after-work"]
  cuisineTags  String[] @default([]) // doubles as categories
  isFeatured   Boolean  @default(false)
  isClaimed    Boolean  @default(false)
  isVerified   Boolean  @default(false)

  // Provenance — set when a row was imported from an external provider.
  source         String? // "foursquare" | "googlePlaces" | "yelp" | "manual" | "submission"
  sourceId       String? // the provider's own id for this venue
  confidenceScore Float? // 0-1, importer's confidence the data is good
  lastSyncedAt   DateTime?

  deals       Deal[]
  events      Event[]
  submissions Submission[]
  claims      BusinessClaim[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([cityId])
  @@index([lat, lng])
  @@index([isVerified])
}

model Deal {
  id          String    @id @default(cuid())
  placeId     String
  place       Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        DealType
  // Recurring schedule — JSON array of weekday windows.
  // e.g. [{ "day":"MON", "start":"16:00", "end":"19:00" }, ...]
  schedule    Json
  startsAt    DateTime? // for one-off deals
  endsAt      DateTime?
  priceHint   String? // "$5 cocktails", "Half-off apps" — the human-readable price text

  // Verification + provenance — deal data is the trust-critical part of CitySip.
  verified        Boolean @default(false)
  source          String  @default("manual") // manual | submission | business | import
  confidenceScore Float? // 0-1

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([placeId])
  @@index([verified])
}

enum DealType {
  FOOD
  DRINK
  BOTH
  EVENT
}

model Event {
  id          String   @id @default(cuid())
  placeId     String?
  place       Place?   @relation(fields: [placeId], references: [id])
  cityId      String
  city        City     @relation(fields: [cityId], references: [id])
  title       String
  description String?
  category    String // trivia | live-music | karaoke | comedy | sports | networking | rooftop
  startsAt    DateTime
  endsAt      DateTime?
  isFree      Boolean  @default(true)
  imageUrl    String?

  // Filled in for externally imported events (e.g. Ticketmaster).
  venueName    String?
  address      String?
  lat          Float?
  lng          Float?
  url          String?
  source       String? // "ticketmaster" | "manual"
  sourceId     String?
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, sourceId])
  @@index([cityId, startsAt])
}

model Submission {
  id        String   @id @default(cuid())
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id])
  type      String // new-place | update-deal | menu-photo | report-error
  payload   Json
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BusinessClaim {
  id        String   @id @default(cuid())
  placeId   String?
  place     Place?   @relation(fields: [placeId], references: [id])
  email     String
  fullName  String
  venueName String?
  message   String?
  payload   Json? // any extra fields from the claim form
  status    String   @default("pending") // pending | approved | rejected
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
