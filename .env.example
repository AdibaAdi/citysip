# ─────────────────────────────────────────────────────────────
# CitySip environment variables
# Copy this file to `.env` and fill in your own values.
# ─────────────────────────────────────────────────────────────

# Postgres connection string (Prisma).
# Local example:
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/citysip?schema=public"
# If you don't want to set this up yet, leave it empty — the app
# automatically falls back to bundled mock data so the UI still works.
DATABASE_URL=""

# Anthropic API key (for the AI search / deal classifier).
# Get one at https://console.anthropic.com — without this the AI search
# falls back to a deterministic keyword matcher.
ANTHROPIC_API_KEY=""

# Optional: external map / data providers (not required for the demo)
NEXT_PUBLIC_MAPBOX_TOKEN=""
GOOGLE_PLACES_API_KEY=""
YELP_API_KEY=""
FOURSQUARE_API_KEY=""

# Admin gate (super simple — replace with real auth later)
ADMIN_TOKEN="change-me-locally"
